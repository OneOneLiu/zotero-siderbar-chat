{
  "name": "zotero-research-copilot",
  "type": "module",
  "version": "2.4.4",
  "description": "Zotero Research Copilot — AI research assistant for Zotero: reader sidebar chat, library-wide assistant, and multi-paper analysis. Works with Gemini, OpenAI-compatible APIs, DeepSeek, Doubao, and other models.",
  "homepage": "https://github.com/OneOneLiu/Zotero-Research-Copilot",
  "author": "Your Name",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneOneLiu/Zotero-Research-Copilot.git"
  },
  "config": {
    "addonName": "Zotero Research Copilot",
    "uiName": "Research Copilot",
    "addonID": "sidebar-chat@local",
    "addonRef": "SidebarChat",
    "addonInstance": "SidebarChat",
    "prefsPrefix": "extensions.zotero.sidebarChat"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "release": "zotero-plugin release",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "@types/markdown-it": "^14.1.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.38",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.13.0",
    "zotero-plugin-toolkit": "^5.1.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.3"
  }
}